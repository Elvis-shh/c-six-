# ── Docker 镜像源（国内环境可保留默认） ──
PYTHON_IMAGE=m.daocloud.io/docker.io/library/python:3.11-slim
NODE_IMAGE=docker.1ms.run/library/node:18-alpine
NGINX_IMAGE=docker.1ms.run/library/nginx:alpine
BUILDER_IMAGE=m.daocloud.io/docker.io/library/maven:3.9-eclipse-temurin-17
RUNTIME_IMAGE=m.daocloud.io/docker.io/library/eclipse-temurin:17-jre
REDIS_IMAGE=m.daocloud.io/docker.io/library/redis:7-alpine
NPM_REGISTRY=https://registry.npmmirror.com
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public

# ── JWT ──
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=86400
